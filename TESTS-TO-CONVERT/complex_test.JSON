  "pages": {
    "HomePage": {
      "elements": ["formSection", "alertSection", "windowSection", "frameSection", "dragDropArea", "widgets", "tables", "uploadInput", "downloadButton"],
      "methods": ["goto()", "scrollTo(sectionName)"]
    },
    "FormPage": {
      "elements": ["firstNameInput", "lastNameInput", "genderMaleRadio", "experienceRadio", "dateInput", "automationCheckbox", "manualCheckbox", "continentsDropdown", "seleniumCommandsSelect", "submitButton"],
      "methods": ["fillForm(data)", "submit()"]
    },
    "AlertPage": {
      "elements": ["alertButton", "confirmButton", "promptButton"],
      "methods": ["triggerAlert()", "triggerConfirm()", "triggerPrompt(text)"]
    },
    "WindowPage": {
      "elements": ["newWindowButton", "newMessageWindowButton", "newTabButton"],
      "methods": ["openWindow()", "openMessageWindow()", "openTab()"]
    },
    "FramePage": {
      "elements": ["frame1Input", "frame2Button"],
      "methods": ["switchToFrame(id)", "enterTextInFrame(text)", "clickFrameButton()"]
    },
    "DragDropPage": {
      "elements": ["draggable", "droppable"],
      "methods": ["dragToDrop()"]
    },
    "WidgetsPage": {
      "elements": ["selectableItems", "sortableItems", "resizableBox", "slider", "datePicker"],
      "methods": ["selectItem(index)", "sortItems()", "resizeBox()", "moveSlider(value)", "pickDate(date)"]
    },
    "TablePage": {
      "elements": ["tableHeaders", "searchBox", "pagination"],
      "methods": ["sortBy(column)", "search(text)", "paginate(page)"]
    },
    "UploadDownloadPage": {
      "elements": ["uploadInput", "downloadButton"],
      "methods": ["upload(file)", "download()"]
    },
    "DynamicPropertiesPage": {
      "elements": ["enableAfterButton", "colorChangeButton", "visibilityAfterButton"],
      "methods": ["waitForEnable()", "waitForColorChange()", "clickVisibilityAfter()"]
    }
  },
  "test_data": {
    "first_name": "John",
    "last_name": "Smith",
    "date": "01/01/2025",
    "prompt_text": "Hello",
    "search_term": "India"
  },
  "assertions": [
    "Homepage loads",
    "Form fields accept input",
    "Alerts behave correctly",
    "Windows and tabs open and close",
    "Frames accept input",
    "Drag and drop succeeds",
    "Widgets respond to interaction",
    "Table sorting works",
    "Search filters rows",
    "Pagination loads pages",
    "File upload succeeds",
    "File download triggers",
    "Dynamic properties update",
    "No console errors"
  ]
